d>\r\n\r\n\r\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Ecs.Collections.ArchetypeNeighborCache._v3' data-commentId='F:Alis.Core.Ecs.Collections.ArchetypeNeighborCache._v3' id='Alis_Core_Ecs_Collections_ArchetypeNeighborCache__v3'>_v3    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Collections/ArchetypeNeighborCache.cs#L55'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Collections.ArchetypeNeighborCache.yml\" sourceStartLineNumber=\"1\">The</p>\n<pre><code class='lang-csharp'>private ushort _v3</code></pre><h4 class='section'>Field Value</h4><dl class='parameters'><dt> <a href='https://learn.microsoft.com/dotnet/api/system.uint16'>ushort</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h2 class='section'>Methods</h2><h3 class='section api' data-uid='Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Lookup(System.Int32)' data-commentId='M:Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Lookup(System.Int32)' id='Alis_Core_Ecs_Collections_ArchetypeNeighborCache_Lookup_System_Int32_'>Lookup(int)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Collections/ArchetypeNeighborCache.cs#L95'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Collections.ArchetypeNeighborCache.yml\" sourceStartLineNumber=\"1\">Returns the destination archetype ID stored at <code class=\"paramref\">index</code>.</p>\n<pre><code class='lang-csharp'>public ushort Lookup(int index)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>index</code> <a href='https://learn.microsoft.com/dotnet/api/system.int32'>int</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h4 class='section'>Returns</h4><dl class='parameters'><dt> <a href='https://learn.microsoft.com/dotnet/api/system.uint16'>ushort</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Set(System.UInt16,System.UInt16)' data-commentId='M:Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Set(System.UInt16,System.UInt16)' id='Alis_Core_Ecs_Collections_ArchetypeNeighborCache_Set_System_UInt16_System_UInt16_'>Set(ushort, ushort)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Collections/ArchetypeNeighborCache.cs#L108'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Collections.ArchetypeNeighborCache.yml\" sourceStartLineNumber=\"1\">Stores a key→value mapping (ushort only, no direct Archetype reference).</p>\n<pre><code class='lang-csharp'>public void Set(ushort key, ushort value)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>key</code> <a href='https://learn.microsoft.com/dotnet/api/system.uint16'>ushort</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd><dt><code>value</code> <a href='https://learn.microsoft.com/dotnet/api/system.uint16'>ushort</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Set(System.UInt16,Alis.Core.Ecs.Kernel.Archetypes.Archetype)' data-commentId='M:Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Set(System.UInt16,Alis.Core.Ecs.Kernel.Archetypes.Archetype)' id='Alis_Core_Ecs_Collections_ArchetypeNeighborCache_Set_System_UInt16_Alis_Core_Ecs_Kernel_Archetypes_Archetype_'>Set(ushort, Archetype)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Collections/ArchetypeNeighborCache.cs#L126'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Collections.ArchetypeNeighborCache.yml\" sourceStartLineNumber=\"1\">Stores a key→archetype mapping. The destination archetype ID is derived from\n<code class=\"paramref\">archetype</code> and the reference is cached for the fast hit path.</p>\n<pre><code class='lang-csharp'>public void Set(ushort key, Archetype archetype)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>key</code> <a href='https://learn.microsoft.com/dotnet/api/system.uint16'>ushort</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd><dt><code>archetype</code> <a href='Alis.Core.Ecs.Kernel.Archetypes.Archetype.html'>Archetype</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Traverse(System.UInt16)' data-commentId='M:Alis.Core.Ecs.Collections.ArchetypeNeighborCache.Traverse(System.UInt16)' id='Alis_Core_Ecs_Collections_ArchetypeNeighborCache_Traverse_System_UInt16_'>Traverse(ushort)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Collections/ArchetypeNeighborCache.cs#L70'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Collections.ArchetypeNeighborCache.yml\" sourceStartLineNumber=\"1\">Returns the slot index (0-3) for <code class=\"paramref\">value</code>, or 32 on miss.</p>\n<pre><code class='lang-csharp'>public int Traverse(ushort value)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>value</code> <a href='https://learn.microsoft.com/dotnet/api/system.uint16'>ushort</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h4 class='section'>Returns</h4><dl class='parameters'><dt> <a href='https://learn.microsoft.com/dotnet/api/system.int32'>int</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Ecs.Collections.ArchetypeNeighborCache.TraverseArchetype(System.UInt16)' data-commentId='M:Alis.Core.Ecs.Collections.ArchetypeNeighborCache.TraverseArchetype(System.UInt16)' id='Alis_Core_Ecs_Collections_ArchetypeNeighborCache_TraverseArchetype_System_UInt16_'>TraverseArchetype(ushort)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Collections/ArchetypeNeighborCache.cs#L84'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Collections.ArchetypeNeighborCache.yml\" sourceStartLineNumber=\"1\">Returns the cached <xref href=\"Alis.Core.Ecs.Kernel.Archetypes.Archetype\" data-throw-if-not-resolved=\"false\"></xref> for <code class=\"paramref\">key</code> directly,\nor <a href=\"https://learn.microsoft.com/dotnet/csharp/language-reference/keywords/null\">null</a> on a miss. Eliminates the WorldArchetypeTable lookup on the hot path.</p>\n<pre><code class='lang-csharp'>public Archetype TraverseArchetype(ushort key)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>key</code> <a href='https://learn.microsoft.com/dotnet/api/system.uint16'>ushort</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h4 class='section'>Returns</h4><dl class='parameters'><dt> <a href='Alis.Core.Ecs.Kernel.Archetypes.Archetype.html'>Archetype</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl>",
