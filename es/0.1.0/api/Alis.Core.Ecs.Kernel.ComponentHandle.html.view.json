ed_Alis_Core_Ecs_Kernel_ComponentId_System_Object_'>CreateFromBoxed(ComponentId, object)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Kernel/ComponentHandle.cs#L96'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">Creates a new <xref href=\"Alis.Core.Ecs.Kernel.ComponentHandle\" data-throw-if-not-resolved=\"false\"></xref> from a potentially boxed component.</p>\n<pre><code class='lang-csharp'>public static ComponentHandle CreateFromBoxed(ComponentId typeAs, object @object)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>typeAs</code> <a href='Alis.Core.Ecs.Kernel.ComponentId.html'>ComponentId</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">The type to store the component as.</p>\n\r\n</dd><dt><code>object</code> <a href='https://learn.microsoft.com/dotnet/api/system.object'>object</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">The potentially boxed component to store.</p>\n\r\n</dd></dl><h4 class='section'>Returns</h4><dl class='parameters'><dt> <a href='Alis.Core.Ecs.Kernel.ComponentHandle.html'>ComponentHandle</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">A <xref href=\"Alis.Core.Ecs.Kernel.ComponentHandle\" data-throw-if-not-resolved=\"false\"></xref> instance that can be used to retrieve <code class=\"paramref\">object</code>.</p>\n\r\n</dd></dl><h4 class='section'>Exceptions</h4><dl class='parameters'><dt> <a href='https://learn.microsoft.com/dotnet/api/system.invalidcastexception'>InvalidCastException</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\"><code class=\"paramref\">object</code> is not of <code class=\"paramref\">typeAs.Type.Type</code></p>\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Ecs.Kernel.ComponentHandle.CreateFromBoxed(System.Object)' data-commentId='M:Alis.Core.Ecs.Kernel.ComponentHandle.CreateFromBoxed(System.Object)' id='Alis_Core_Ecs_Kernel_ComponentHandle_CreateFromBoxed_System_Object_'>CreateFromBoxed(object)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Kernel/ComponentHandle.cs#L107'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">Creates a new <xref href=\"Alis.Core.Ecs.Kernel.ComponentHandle\" data-throw-if-not-resolved=\"false\"></xref> from a potentially boxed component.</p>\n<pre><code class='lang-csharp'>public static ComponentHandle CreateFromBoxed(object @object)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>object</code> <a href='https://learn.microsoft.com/dotnet/api/system.object'>object</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">The potentially boxed component to store.</p>\n\r\n</dd></dl><h4 class='section'>Returns</h4><dl class='parameters'><dt> <a href='Alis.Core.Ecs.Kernel.ComponentHandle.html'>ComponentHandle</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">A <xref href=\"Alis.Core.Ecs.Kernel.ComponentHandle\" data-throw-if-not-resolved=\"false\"></xref> instance that can be used to retrieve <code class=\"paramref\">object</code>.</p>\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Ecs.Kernel.ComponentHandle.Dispose' data-commentId='M:Alis.Core.Ecs.Kernel.ComponentHandle.Dispose' id='Alis_Core_Ecs_Kernel_ComponentHandle_Dispose'>Dispose()    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Kernel/ComponentHandle.cs#L150'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">Frees the memory associated with this component handle and marks it for reuse.</p>\n<pre><code class='lang-csharp'>public void Dispose()</code></pre><h4 class='section'>Remarks</h4><p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">It is very easy to leak memory by improperly disposing of <xref href=\"Alis.Core.Ecs.Kernel.ComponentHandle\" data-throw-if-not-resolved=\"false\"></xref> instances. The handle\ndoes not check for double disposes.</p>\n<h3 class='section api' data-uid='Alis.Core.Ecs.Kernel.ComponentHandle.Equals(Alis.Core.Ecs.Kernel.ComponentHandle)' data-commentId='M:Alis.Core.Ecs.Kernel.ComponentHandle.Equals(Alis.Core.Ecs.Kernel.ComponentHandle)' id='Alis_Core_Ecs_Kernel_ComponentHandle_Equals_Alis_Core_Ecs_Kernel_ComponentHandle_'>Equals(ComponentHandle)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Ecs/src/Kernel/ComponentHandle.cs#L160'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">Checks if a <xref href=\"Alis.Core.Ecs.Kernel.ComponentHandle\" data-throw-if-not-resolved=\"false\"></xref> is equal to this handle and so points to the same component.</p>\n<pre><code class='lang-csharp'>public bool Equals(ComponentHandle other)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>other</code> <a href='Alis.Core.Ecs.Kernel.ComponentHandle.html'>ComponentHandle</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Ecs.Kernel.ComponentHandle.yml\" sourceStartLineNumber=\"1\">The <xref href=\"Alis.Core.Ecs.Kernel.ComponentHandle\" data-throw-if-not-resolved=\"false\"></xref> to compare t