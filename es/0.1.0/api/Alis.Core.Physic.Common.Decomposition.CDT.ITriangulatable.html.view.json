on.Decomposition.CDT.TriangulationMode.html'>TriangulationMode</a>  </dt>\r\n<dd>\r\n\r\n\r\n\r\n</dd></dl><h2 class='section'>Methods</h2><h3 class='section api' data-uid='Alis.Core.Physic.Common.Decomposition.CDT.ITriangulatable.AddTriangle(Alis.Core.Physic.Common.Decomposition.CDT.Delaunay.DelaunayTriangle)' data-commentId='M:Alis.Core.Physic.Common.Decomposition.CDT.ITriangulatable.AddTriangle(Alis.Core.Physic.Common.Decomposition.CDT.Delaunay.DelaunayTriangle)' id='Alis_Core_Physic_Common_Decomposition_CDT_ITriangulatable_AddTriangle_Alis_Core_Physic_Common_Decomposition_CDT_Delaunay_DelaunayTriangle_'>AddTriangle(DelaunayTriangle)    <a class='header-action link-secondary' title='View source' href='https://github.com/pabllopf/Alis/blob/master/4_Operation/Physic/src/Common/Decomposition/CDT/ITriangulatable.cs#L65'><i class='bi bi-code-slash'></i></a></h3>\r\n <p sourceFile=\"api/Alis.Core.Physic.Common.Decomposition.CDT.ITriangulatable.yml\" sourceStartLineNumber=\"1\">Adds the triangle using the specified t</p>\n<pre><code class='lang-csharp'>void AddTriangle(DelaunayTriangle t)</code></pre><h4 class='section'>Parameters</h4><dl class='parameters'><dt><code>t</code> <a href='Alis.Core.Physic.Common.Decomposition.CDT.Delaunay.DelaunayTriangle.html'>DelaunayTriangle</a>  </dt>\r\n<dd>\r\n\r\n\r\n<p sourceFile=\"api/Alis.Core.Physic.Common.Decomposition.CDT.ITriangulatable.yml\" sourceStartLineNumber=\"1\">The</p>\n\r\n</dd></dl><h3 class='section api' data-uid='Alis.Core.Physic.Common.Decomposition.CDT.ITriangulatable.AddTriangles(System.Collections.Generic.IEnumerable{Alis.Core.Physic.Common.Decomposition.CDT.Delaunay.DelaunayTriangle})' data-commentId='M:Alis.Core.Physic.Common.Decomposition.CDT.ITriangulatable.AddTriangles(System.Collections.Generic.IEnumerable{Alis.Core.Physic.Common.Decomposition.CDT.Delaunay.DelaunayTriangle})' id='Alis_Core_Physic_Common_Decomposition_CDT_ITriangulatable_AddTriangles_System_Collections_Generic_IEnumerable_Alis_Core_Physic